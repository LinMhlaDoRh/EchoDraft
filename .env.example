# Server-side only. Never prefix with NEXT_PUBLIC_ and never commit real secrets.
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash

# REQUIRED in production (fail-closed). The durable API guard (N-01 / N-02).
# - Browser users: middleware sets a signed httpOnly session cookie derived from this secret.
# - Automation: send header  x-echodraft-token: <value>  OR  Authorization: Bearer <value>
# Generate with:  openssl rand -hex 32
ECHODRAFT_API_TOKEN=

# Optional separate signing secret for browser session cookies.
# Defaults to ECHODRAFT_API_TOKEN when unset.
# ECHODRAFT_SESSION_SECRET=

# Optional rate limit (defense-in-depth only — resets on serverless cold start)
# ECHODRAFT_RATE_LIMIT_MAX=20
# ECHODRAFT_RATE_LIMIT_WINDOW_MS=60000
